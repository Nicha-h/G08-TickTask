{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --clean",
    "start": "node dist/index.cjs",
    "migrate": "prisma migrate dev",
    "seed": "tsx prisma/users.seed.ts",
    "seed:roles": "tsx prisma/roles.seed.ts",
    "seed:all": "tsx prisma/roles.seed.ts && tsx prisma/users.seed.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "check": "eslint . && prettier --check .",
    "test": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/standard-validator": "^0.2.2",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "@prisma/client": "^6.7.0",
    "@valibot/to-json-schema": "^1.6.0",
    "axios": "^1.8.4",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.6.1",
    "dotenv": "^16.4.7",
    "formidable": "^3.5.4",
    "hono": "^4.12.12",
    "hono-openapi": "^1.3.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.0",
    "nodemailer": "^8.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/formidable": "^3.4.5",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.11.17",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^6.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.7.1",
    "typescript": "^6.0.2"
  }
}
